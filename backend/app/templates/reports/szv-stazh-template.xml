<?xml version="1.0" encoding="UTF-8"?>
<!--
  СЗВ-СТАЖ — сведения о стаже застрахованных лиц (годовая форма) — упрощённая модель.
-->
<СЗВ_СТАЖ
  xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
  ТипСведений="ИСХД"
  ОтчетныйПериод="{{ report_year }}">
  <СведСтрахователя
    РегНомПФ="{{ pf_reg_number }}"
    ИНН="{{ inn }}"
    КПП="{{ kpp }}"
    НаимОрг="{{ org_name }}"/>
  <СведЗастрахЛиц>
    {% for row in employees %}
    <СведЗастрахЛица
      СНИЛС="{{ row.snils }}"
      Фамилия="{{ row.last_name }}"
      Имя="{{ row.first_name }}"
      Отчество="{{ row.middle_name }}"
      ДатНач="01.01.{{ report_year }}"
      ДатКон="31.12.{{ report_year }}"
      ВидЗаним="ОСНОВН"/>
    {% endfor %}
  </СведЗастрахЛиц>
</СЗВ_СТАЖ>
