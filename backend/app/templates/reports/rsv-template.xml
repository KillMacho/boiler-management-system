<?xml version="1.0" encoding="UTF-8"?>
<!--
  РСВ — Расчёт по страховым взносам (КНД 1151111) — упрощённая модель для диплома.
-->
<Файл
  ИдФайл="NO_RSV_{{ inn }}_{{ inn }}_{{ id_file }}"
  ВерсФорм="1.0">
  <Документ
    КНД="1151111"
    ДатаДок="{{ date_doc }}"
    Период="{{ period_code }}"
    ОтчетГод="{{ report_year }}">
    <СвНП>
      <НПЮЛ ИННЮЛ="{{ inn }}" КПП="{{ kpp }}" НаимОрг="{{ org_name }}"/>
    </СвНП>
    <РасчСВ>
      <СвОПС КолЗастрЛиц="{{ employee_count }}" СумВознагрОПС="{{ total_income }}" БазОПС="{{ total_income }}" СумСВ="{{ pf_amount }}"/>
      <СвОМС КолЗастрЛиц="{{ employee_count }}" СумВознагрОМС="{{ total_income }}" БазОМС="{{ total_income }}" СумСВ="{{ oms_amount }}"/>
      <СвОСС КолЗастрЛиц="{{ employee_count }}" СумВознагрОСС="{{ total_income }}" БазОСС="{{ total_income }}" СумСВ="{{ fss_amount }}"/>
    </РасчСВ>
    <ПерСведения>
      {% for row in employees %}
      <СведФЛ
        СНИЛС="{{ row.snils }}"
        Фамилия="{{ row.last_name }}"
        Имя="{{ row.first_name }}"
        Отчество="{{ row.middle_name }}"
        СумВознагр="{{ row.income }}"
        СумСВ="{{ row.pf_contrib }}"/>
      {% endfor %}
    </ПерСведения>
  </Документ>
</Файл>
