<?xml version="1.0" encoding="UTF-8"?>
<!--
  Форма 4-ФСС — расчёт по взносам на травматизм — упрощённая модель для диплома.
-->
<Файл
  ИдФайл="FSS_4FSS_{{ inn }}_{{ inn }}_{{ id_file }}"
  ВерсФорм="9.0">
  <Документ
    КНД="1151111"
    ДатаДок="{{ date_doc }}"
    Период="{{ period_code }}"
    ОтчетГод="{{ report_year }}">
    <Страхователь
      ИННЮЛ="{{ inn }}"
      КПП="{{ kpp }}"
      НаимОрг="{{ org_name }}"
      РегНомФСС="{{ fss_reg_number }}"/>
    <Таблица1>
      <СредЧисло>{{ employee_count }}</СредЧисло>
      <НачисленВзносы>{{ fss_injury_amount }}</НачисленВзносы>
      <ФактЗатраты>0.00</ФактЗатраты>
      <КОплате>{{ fss_injury_amount }}</КОплате>
    </Таблица1>
    <Таблица3>
      {% for row in employees %}
      <СтраховательФЛ
        Фамилия="{{ row.last_name }}"
        Имя="{{ row.first_name }}"
        Отчество="{{ row.middle_name }}"
        СумВознагр="{{ row.income }}"
        СумВзнос="{{ row.fss_injury }}"/>
      {% endfor %}
    </Таблица3>
  </Документ>
</Файл>
