<?xml version="1.0" encoding="UTF-8"?>
<!--
  Форма 6-НДФЛ (КНД 1151100) — упрощённая модель для диплома.
  Для промышленной версии требуется доводка под актуальный XSD ФНС.
-->
<Файл
  xmlns:xs="http://www.w3.org/2001/XMLSchema-instance"
  ИдФайл="NO_NDFL6_{{ inn }}_{{ inn }}_{{ id_file }}"
  ВерсФорм="5.04"
  ВерсПрог="1.0">
  <Документ
    КНД="1151100"
    ДатаДок="{{ date_doc }}"
    Период="{{ period_code }}"
    ОтчетГод="{{ report_year }}"
    НомКорр="0"
    ПрМесту="214">
    <СвНП>
      <НПЮЛ
        ИННЮЛ="{{ inn }}"
        КПП="{{ kpp }}"
        НаимОрг="{{ org_name }}"/>
    </СвНП>
    <Подписант ПрПодп="1">
      <ФИО Фамилия="{{ signer_last }}" Имя="{{ signer_first }}" Отчество="{{ signer_middle }}"/>
    </Подписант>
    <Ндфл6>
      <Раздел1 КБК="18210102010011000110">
        <ОбобщПоказ
          СтавНал="13"
          СумНалИсчисл="{{ ndfl_accrued }}"
          СумНалУдерж="{{ ndfl_withheld }}"
          СумНалПеречисл="{{ ndfl_transferred }}"/>
      </Раздел1>
      <Раздел2 СтавНал="13" КБК="18210102010011000110">
        {% for row in employees %}
        <ДохВыч
          ИННФЛ="{{ row.inn_fl }}"
          Фамилия="{{ row.last_name }}"
          Имя="{{ row.first_name }}"
          Отчество="{{ row.middle_name }}"
          СумДох="{{ row.income }}"
          СумВыч="0.00"
          СумНалИсчисл="{{ row.ndfl }}"
          СумНалУдерж="{{ row.ndfl }}"/>
        {% endfor %}
      </Раздел2>
    </Ндфл6>
  </Документ>
</Файл>
