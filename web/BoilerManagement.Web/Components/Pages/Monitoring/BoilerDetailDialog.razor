@using BoilerManagement.Web.Services
@using BoilerManagement.Web.Services.DTOs
@inject MonitoringService MonitoringService

<MudDialog Style="min-width:700px;max-width:95vw">
    <TitleContent>
        <MudIcon Icon="@Icons.Material.Filled.Whatshot" Class="mr-2" />
        @BoilerName
    </TitleContent>
    <DialogContent>
        <MudTabs Elevation="0" Rounded="true" ApplyEffectsToContainer="true" PanelClass="pa-2">

            <!-- Вкладка: Параметры (последние значения) -->
            <MudTabPanel Text="Параметры">
                @if (_history.Count == 0 && _loading)
                {
                    <MudProgressLinear Indeterminate="true" />
                }
                else if (_history.Count == 0)
                {
                    <MudAlert Severity="Severity.Info">Нет данных телеметрии</MudAlert>
                }
                else
                {
                    var latest = _history[0];
                    <MudSimpleTable Dense="true" Striped="true" Hover="true">
                        <thead><tr>
                            <th>Параметр</th><th>Значение</th><th>Норма</th>
                        </tr></thead>
                        <tbody>
                            @foreach (var row in _paramDefs)
                            {
                                var val = row.Getter(latest);
                                <tr>
                                    <td>@row.Label</td>
                                    <td><strong>@(val.HasValue ? $"{val:F2} {row.Unit}" : "—")</strong></td>
                                    <td style="color:var(--mud-palette-text-secondary)">@row.Norm</td>
                                </tr>
                            }
                        </tbody>
                    </MudSimpleTable>
                    <MudText Typo="Typo.caption" Class="mt-2 ml-1" Style="color:var(--mud-palette-text-secondary)">
                        Последнее обновление: @latest.Timestamp.ToLocalTime().ToString("HH:mm:ss dd.MM.yyyy")
                    </MudText>
                }
            </MudTabPanel>

            <!-- Вкладка: Графики -->
            <MudTabPanel Text="Графики (24ч)" @onclick:preventDefault>
                @if (_loading)
                {
                    <MudProgressLinear Indeterminate="true" />
                }
                else if (_history.Count < 2)
                {
                    <MudAlert Severity="Severity.Info">Недостаточно данных для построения графика</MudAlert>
                }
                else
                {
                    <MudSelect T="string" @bind-Value="_selectedParam" Label="Параметр" Variant="Variant.Outlined"
                               Dense="true" Class="mb-4" Style="max-width:300px">
                        @foreach (var p in _paramDefs)
                        {
                            <MudSelectItem Value="@p.Key">@p.Label</MudSelectItem>
                        }
                    </MudSelect>

                    <MudChart ChartType="ChartType.Line"
                              ChartSeries="@BuildChartData(_selectedParam).Series"
                              XAxisLabels="@BuildChartData(_selectedParam).Labels"
                              Width="100%" Height="280px"
                              ChartOptions="@_chartOptions" />
                }
            </MudTabPanel>

            <!-- Вкладка: Связанные заявки -->
            <MudTabPanel Text="Заявки">
                @if (_alarms.Count == 0)
                {
                    <MudAlert Severity="Severity.Success">Нет активных аварийных заявок</MudAlert>
                }
                else
                {
                    <MudSimpleTable Dense="true" Striped="true">
                        <thead><tr><th>Номер</th><th>Статус</th><th>Описание</th><th>Создана</th></tr></thead>
                        <tbody>
                            @foreach (var a in _alarms)
                            {
                                <tr>
                                    <td><MudChip T="string" Size="Size.Small" Color="Color.Warning">@a.Number</MudChip></td>
                                    <td>@a.Status</td>
                                    <td>@a.Description</td>
                                    <td>@a.CreatedAt.ToLocalTime().ToString("dd.MM HH:mm")</td>
                                </tr>
                            }
                        </tbody>
                    </MudSimpleTable>
                }
            </MudTabPanel>

        </MudTabs>
    </DialogContent>
    <DialogActions>
        <MudButton OnClick="Close" Variant="Variant.Filled" Color="Color.Primary">Закрыть</MudButton>
    </DialogActions>
</MudDialog>

@code {
    [CascadingParameter] IMudDialogInstance MudDialog { get; set; } = null!;
    [Parameter] public int BoilerId { get; set; }
    [Parameter] public string BoilerName { get; set; } = "";
    [Parameter] public List<ActiveAlarmDto> Alarms { get; set; } = [];

    private List<TelemetryHistoryDto> _history = [];
    private List<ActiveAlarmDto> _alarms = [];
    private bool _loading = true;
    private string _selectedParam = "temperature_heat";

    private readonly ChartOptions _chartOptions = new()
    {
        YAxisLines = true,
        YAxisTicks = 5,
        MaxNumYAxisTicks = 6,
        LineStrokeWidth = 2,
    };

    private record ParamDef(string Key, string Label, string Unit, string Norm,
        Func<TelemetryHistoryDto, decimal?> Getter);

    private readonly List<ParamDef> _paramDefs =
    [
        new("temperature_heat",   "Температура подачи",   "°C",    "75–90",     h => h.TemperatureHeat),
        new("pressure",           "Давление",             "МПа",   "0.55–0.65", h => h.Pressure),
        new("co_level",           "CO",                   "мг/м³", "<50",       h => h.CoLevel),
        new("gas_flow",           "Расход газа",          "м³/ч",  "—",         h => h.GasFlow),
        new("water_level",        "Уровень воды",         "%",     ">50",       h => h.WaterLevel),
        new("temperature_return", "Температура обратки",  "°C",    "50–60",     h => h.TemperatureReturn),
        new("furnace_draft",      "Разрежение",           "Па",    "-35…-25",   h => h.FurnaceDraft),
    ];

    protected override async Task OnInitializedAsync()
    {
        _alarms = Alarms.Where(a => a.BoilerId == BoilerId).ToList();
        _history = await MonitoringService.GetHistoryAsync(BoilerId, hours: 24, limit: 200);
        _history = [.. _history.OrderByDescending(h => h.Timestamp)];
        _loading = false;
    }

    private (List<ChartSeries> Series, string[] Labels) BuildChartData(string paramKey)
    {
        var def = _paramDefs.FirstOrDefault(p => p.Key == paramKey);
        if (def is null) return ([], []);

        // Take up to 50 points, oldest first for chart
        var points = _history.TakeLast(50).ToList();
        var labels = points.Select(h => h.Timestamp.ToLocalTime().ToString("HH:mm")).ToArray();
        var values = points.Select(h => (double)(def.Getter(h) ?? 0)).ToArray();

        return ([new ChartSeries { Name = def.Label, Data = values }], labels);
    }

    private void Close() => MudDialog.Close();
}
