@page "/login"
@layout LoginLayout
@inject AuthService AuthService
@inject NavigationManager Navigation

<PageTitle>Вход — Котельный сервис</PageTitle>

<MudCard Elevation="4" Class="pa-6" Style="width: 100%; max-width: 420px;">
    <MudCardHeader>
        <CardHeaderContent>
            <MudText Typo="Typo.h5" Align="Align.Center">
                <MudIcon Icon="@Icons.Material.Filled.Whatshot" Color="Color.Primary" Class="mr-2" />
                Котельный сервис
            </MudText>
            <MudText Typo="Typo.body2" Align="Align.Center" Color="Color.Secondary" Class="mt-1">
                Информационная система управления котельными
            </MudText>
        </CardHeaderContent>
    </MudCardHeader>

    <MudCardContent>
        <EditForm Model="_model" OnValidSubmit="HandleLoginAsync">
            <DataAnnotationsValidator />

            <MudTextField @bind-Value="_model.Username"
                          Label="Имя пользователя"
                          Variant="Variant.Outlined"
                          Adornment="Adornment.Start"
                          AdornmentIcon="@Icons.Material.Filled.Person"
                          Class="mb-4"
                          Disabled="_isLoading"
                          Required="true"
                          RequiredError="Введите имя пользователя" />

            <MudTextField @bind-Value="_model.Password"
                          Label="Пароль"
                          Variant="Variant.Outlined"
                          InputType="_passwordInputType"
                          Adornment="Adornment.End"
                          AdornmentIcon="@_passwordIcon"
                          OnAdornmentClick="TogglePasswordVisibility"
                          Class="mb-6"
                          Disabled="_isLoading"
                          Required="true"
                          RequiredError="Введите пароль" />

            <MudButton ButtonType="ButtonType.Submit"
                       Variant="Variant.Filled"
                       Color="Color.Primary"
                       FullWidth="true"
                       Size="Size.Large"
                       Disabled="_isLoading">
                @if (_isLoading)
                {
                    <MudProgressCircular Size="Size.Small" Indeterminate="true" Class="mr-2" />
                    <span>Вход...</span>
                }
                else
                {
                    <span>Войти</span>
                }
            </MudButton>
        </EditForm>
    </MudCardContent>
</MudCard>

@code {
    private readonly LoginModel _model = new();
    private bool _isLoading;
    private bool _showPassword;
    private InputType _passwordInputType = InputType.Password;
    private string _passwordIcon = Icons.Material.Filled.VisibilityOff;

    [SupplyParameterFromQuery]
    private string? ReturnUrl { get; set; }

    private void TogglePasswordVisibility()
    {
        _showPassword = !_showPassword;
        _passwordInputType = _showPassword ? InputType.Text : InputType.Password;
        _passwordIcon = _showPassword
            ? Icons.Material.Filled.Visibility
            : Icons.Material.Filled.VisibilityOff;
    }

    private async Task HandleLoginAsync()
    {
        _isLoading = true;
        try
        {
            var success = await AuthService.LoginAsync(_model.Username, _model.Password);
            if (success)
            {
                var redirect = string.IsNullOrEmpty(ReturnUrl) ? "/" : Uri.UnescapeDataString(ReturnUrl);
                Navigation.NavigateTo(redirect, forceLoad: false);
            }
        }
        finally
        {
            _isLoading = false;
        }
    }

    private sealed class LoginModel
    {
        public string Username { get; set; } = string.Empty;
        public string Password { get; set; } = string.Empty;
    }
}
