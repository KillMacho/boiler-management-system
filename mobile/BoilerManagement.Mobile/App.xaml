<?xml version="1.0" encoding="UTF-8" ?>
<Application
    x:Class="BoilerManagement.Mobile.App"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:conv="clr-namespace:BoilerManagement.Mobile.Converters">
    <Application.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="Resources/Styles/Colors.xaml" />
                <ResourceDictionary Source="Resources/Styles/Styles.xaml" />
            </ResourceDictionary.MergedDictionaries>

            <conv:IsNotEmptyConverter           x:Key="IsNotEmptyConverter" />
            <conv:InverseBoolConverter          x:Key="InverseBoolConverter" />
            <conv:EyeIconConverter              x:Key="EyeIconConverter" />
            <conv:StatusColorConverter          x:Key="StatusColorConverter" />
            <conv:StatusLabelConverter          x:Key="StatusLabelConverter" />
            <conv:CheckedTextDecorationConverter x:Key="CheckedTextDecorationConverter" />
        </ResourceDictionary>
    </Application.Resources>
</Application>
